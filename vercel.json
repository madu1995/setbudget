{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|svg|ico|json|css|js|woff|woff2|ttf|eot))$",
      "destination": "/web/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/web/index.html"
    }
  ]
}