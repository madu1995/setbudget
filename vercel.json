{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(assets/.*)",
      "dest": "/web/$1"
    },
    {
      "src": "/([^/]+\\.[a-z0-9]+)$",
      "dest": "/web/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}